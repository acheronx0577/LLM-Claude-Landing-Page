# ── Next.js (client) ──────────────────────────────────────────────
# Generated automatically when you run `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# Convex deployment name (also set by `npx convex dev`)
CONVEX_DEPLOYMENT=

# ── Convex backend (set with `npx convex env set KEY value`) ─────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered
CONTACT_TO_EMAIL=you@example.com

# Must be a verified sender in Resend (use onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=onboarding@resend.dev
